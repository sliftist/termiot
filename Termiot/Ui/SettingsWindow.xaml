<Window x:Class="Termiot.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termiot Settings"
        Width="560" Height="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF262626">
  <TabControl x:Name="Tabs" Background="#FF262626" BorderThickness="0" Margin="8">
    <TabItem Header="General">
      <StackPanel Margin="12">
        <CheckBox x:Name="ShowEscapesBox"
                  Content="Render escape sequences literally by default for new tabs (right-click a tab to toggle it per tab)"
                  Foreground="#FFDDDDDD"
                  Checked="ShowEscapesBox_Changed"
                  Unchecked="ShowEscapesBox_Changed" />
        <CheckBox x:Name="AutoResumeBox"
                  Content="Resume terminated shells automatically (skip the confirmation)"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="AutoResumeBox_Changed"
                  Unchecked="AutoResumeBox_Changed" />
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
          <TextBlock Text="Multi-complete suggestions (1-100):" Foreground="#FFDDDDDD" VerticalAlignment="Center" />
          <TextBox x:Name="MultiCountBox" Width="60" Margin="8,0,0,0" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="MultiCountBox_TextChanged" />
        </StackPanel>
        <CheckBox x:Name="WriteLogImmediatelyBox"
                  Content="Write shell output to disk immediately (default: batched once per second; applies to newly started shells)"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="WriteLogImmediatelyBox_Changed"
                  Unchecked="WriteLogImmediatelyBox_Changed" />
        <TextBlock Text="Default terminal application:" Foreground="#FFAAAAAA" Margin="0,16,0,0" />
        <TextBlock x:Name="DefaultTerminalStatus" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
          <Button x:Name="MakeDefaultBtn" Content="Make Termiot the default terminal" Padding="10,4" Click="MakeDefaultBtn_Click" />
          <Button x:Name="ResetDefaultBtn" Content="Reset to Windows default" Padding="10,4" Margin="8,0,0,0" Click="ResetDefaultBtn_Click" />
        </StackPanel>
        <TextBlock Text="Per-user registration — no administrator prompt needed. New console windows will open in Termiot." Foreground="#FF777777" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
        <TextBlock x:Name="BuildTimeText" Foreground="#FF777777" FontSize="11" Margin="0,16,0,0" />
      </StackPanel>
    </TabItem>
    <TabItem Header="Shells">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ShellsPanel" Margin="12" />
      </ScrollViewer>
    </TabItem>
    <TabItem x:Name="LlmTab" Header="LLM">
      <StackPanel Margin="12">
        <TextBlock Text="OpenRouter config file (the api key, or JSON with a &quot;key&quot; field):" Foreground="#FFAAAAAA" />
        <DockPanel Margin="0,4,0,0">
          <Button x:Name="BrowseConfigBtn" DockPanel.Dock="Right" Content="Browse…" Padding="10,2" Margin="6,0,0,0" Click="BrowseConfigBtn_Click" />
          <TextBox x:Name="ConfigPathBox" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="ConfigPathBox_TextChanged" />
        </DockPanel>
        <TextBlock Text="Model:" Foreground="#FFAAAAAA" Margin="0,12,0,0" />
        <ContentControl x:Name="ModelBoxHost" Margin="0,4,0,0" />
        <TextBlock x:Name="ModelListStatus" Foreground="#FF777777" FontSize="11" Margin="0,2,0,0" />
        <TextBlock Text="Context window (tokens):" Foreground="#FFAAAAAA" Margin="0,12,0,0" />
        <TextBox x:Name="ContextTokensBox" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="ContextTokensBox_TextChanged" />
        <TextBlock x:Name="LlmStatsText" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,16,0,0" />
        <Button x:Name="ShowContextBtn" Content="Show current context" HorizontalAlignment="Left" Margin="0,12,0,0" Padding="10,4" Click="ShowContextBtn_Click" />
      </StackPanel>
    </TabItem>
  </TabControl>
</Window>
