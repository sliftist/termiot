<Window x:Class="Termiot.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termiot Settings"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF262626">
  <TabControl x:Name="Tabs" Background="#FF262626" BorderThickness="0" Margin="8">
    <TabControl.Resources>
      <Style TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap" />
      </Style>
    </TabControl.Resources>
    <TabItem Header="General">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="12">
        <CheckBox x:Name="ShowEscapesBox"
                  Foreground="#FFDDDDDD"
                  Checked="ShowEscapesBox_Changed"
                  Unchecked="ShowEscapesBox_Changed">
          <TextBlock Text="Render escape sequences literally by default for new tabs (right-click a tab to toggle it per tab)" />
        </CheckBox>
        <CheckBox x:Name="AutoResumeBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="AutoResumeBox_Changed"
                  Unchecked="AutoResumeBox_Changed">
          <TextBlock Text="Resume terminated shells automatically (skip the confirmation)" />
        </CheckBox>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
          <TextBlock Text="Multi-complete suggestions (1-100):" Foreground="#FFDDDDDD" VerticalAlignment="Center" />
          <TextBox x:Name="MultiCountBox" Width="60" Margin="8,0,0,0" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="MultiCountBox_TextChanged" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
          <TextBlock Text="Scrollback history (lines):" Foreground="#FFDDDDDD" VerticalAlignment="Center" />
          <TextBox x:Name="ScrollbackBox" Width="100" Margin="8,0,0,0" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="ScrollbackBox_TextChanged" />
        </StackPanel>
        <CheckBox x:Name="WriteLogImmediatelyBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="WriteLogImmediatelyBox_Changed"
                  Unchecked="WriteLogImmediatelyBox_Changed">
          <TextBlock Text="Write shell output to disk immediately (default: batched once per second; applies to newly started shells)" />
        </CheckBox>
        <CheckBox x:Name="ShowTabResourcesBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="ShowTabResourcesBox_Changed"
                  Unchecked="ShowTabResourcesBox_Changed">
          <TextBlock Text="Show per-tab resource usage above tab titles (memory / dedicated GPU memory / CPU over the last minute, bars scaled to the window's heaviest tab)" />
        </CheckBox>
        <CheckBox x:Name="ShowFpsBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="ShowFpsBox_Changed"
                  Unchecked="ShowFpsBox_Changed">
          <TextBlock Text="Show render FPS in the title bar (painted frames · per-frame cost · sustainable ceiling)" />
        </CheckBox>
        <CheckBox x:Name="SwapEnterBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="SwapEnterBox_Changed"
                  Unchecked="SwapEnterBox_Changed">
          <TextBlock Text="Enter and Ctrl+Enter are swapped: Enter adds a newline to the input; Ctrl+Enter or Shift+Enter submits" />
        </CheckBox>
        <CheckBox x:Name="SingleRowTabsBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="SingleRowTabsBox_Changed"
                  Unchecked="SingleRowTabsBox_Changed">
          <TextBlock Text="Single-row tabs: keep all tabs on one line and scroll horizontally (default: wrap onto as many rows as needed)" />
        </CheckBox>
        <CheckBox x:Name="ReopenOnStartupBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,10,0,0"
                  Checked="ReopenOnStartupBox_Changed"
                  Unchecked="ReopenOnStartupBox_Changed">
          <TextBlock Text="Reopen windows at Windows startup (installs a Startup-folder entry; restores everything open at shutdown)" />
        </CheckBox>
        <TextBlock Text="Default terminal application:" Foreground="#FFAAAAAA" Margin="0,16,0,0" />
        <TextBlock x:Name="DefaultTerminalStatus" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
          <Button x:Name="MakeDefaultBtn" Content="Make Termiot the default terminal" Padding="10,4" Click="MakeDefaultBtn_Click" />
          <Button x:Name="ResetDefaultBtn" Content="Reset to Windows default" Padding="10,4" Margin="8,0,0,0" Click="ResetDefaultBtn_Click" />
        </StackPanel>
        <TextBlock Text="Per-user registration — no administrator prompt needed. New console windows will open in Termiot." Foreground="#FF777777" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
        <TextBlock Text="Cursor external terminal (Ctrl+Shift+C):" Foreground="#FFAAAAAA" Margin="0,16,0,0" />
        <TextBlock x:Name="CursorExecStatus" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
          <Button x:Name="CursorExtBtn" Content="Use the extension (instant, no shell window)" Padding="10,4" Click="CursorExtBtn_Click" />
          <Button x:Name="CursorExecBtn" Content="Use the executable" Padding="10,4" Margin="8,0,0,0" Click="CursorExecBtn_Click" />
        </StackPanel>
        <TextBlock Text="One or the other: the extension binds Ctrl+Shift+C inside Cursor and triggers our local open-tab endpoint with no process spawn; choosing the executable uninstalls the extension. Restart Cursor after switching." Foreground="#FF777777" FontSize="11" Margin="0,2,0,0" />
        <TextBlock Text="Explorer context menu:" Foreground="#FFAAAAAA" Margin="0,16,0,0" />
        <TextBlock x:Name="ContextMenuStatus" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,4,0,0" />
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
          <Button x:Name="ContextMenuBtn" Content="Add 'Open in Termiot' to Explorer" Padding="10,4" Click="ContextMenuBtn_Click" />
          <Button x:Name="ContextMenuRemoveBtn" Content="Remove" Padding="10,4" Margin="8,0,0,0" Click="ContextMenuRemoveBtn_Click" />
        </StackPanel>
        <TextBlock Text="Claude Code:" Foreground="#FFAAAAAA" Margin="0,16,0,0" />
        <TextBlock x:Name="ClaudeHookStatus" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,4,0,0" />
        <Button x:Name="ClaudeHookBtn" Content="Add auto-resume hook to Claude Code" Padding="10,4" Margin="0,6,0,0" HorizontalAlignment="Left" Click="ClaudeHookBtn_Click" />
        <TextBlock Text="Writes `claude -r &lt;session&gt;` to the tab's AUTORESUME.cmd whenever a Claude session starts, so restored tabs resume the exact session that was running in them." Foreground="#FF777777" FontSize="11" Margin="0,2,0,0" />
        <TextBlock Text="Start menu:" Foreground="#FFAAAAAA" Margin="0,16,0,0" />
        <TextBlock x:Name="StartMenuStatus" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,4,0,0" />
        <Button x:Name="StartMenuBtn" Content="Add this executable to the Start menu" Padding="10,4" Margin="0,6,0,0" HorizontalAlignment="Left" Click="StartMenuBtn_Click" />
        <TextBlock Text="Rebuild log (most recent ⟳ reload):" Foreground="#FFAAAAAA" Margin="0,16,0,0" />
        <TextBox x:Name="BuildLogBox" IsReadOnly="True" Height="180" Margin="0,4,0,0"
                 Background="#FF1E1E1E" Foreground="#FFCCCCCC" BorderBrush="#FF555555"
                 FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
        <TextBlock x:Name="BuildTimeText" Foreground="#FF777777" FontSize="11" Margin="0,16,0,0" />
      </StackPanel>
      </ScrollViewer>
    </TabItem>
    <TabItem Header="Shells">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ShellsPanel" Margin="12" />
      </ScrollViewer>
    </TabItem>
    <TabItem Header="Hotkeys">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="HotkeysPanel" Margin="12" />
      </ScrollViewer>
    </TabItem>
    <TabItem Header="Windows">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="WindowsPanel" Margin="12" />
      </ScrollViewer>
    </TabItem>
    <TabItem Header="Startup">
      <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="Renderer startup timeline for this window (ms since process start). Each line is a milestone with the delta since the previous one — the big deltas are where reload time goes." Foreground="#FFAAAAAA" Margin="0,0,0,6" />
        <TextBox x:Name="StartupTraceBox" IsReadOnly="True" Margin="0,0,0,0"
                 Background="#FF1E1E1E" Foreground="#FFCCCCCC" BorderBrush="#FF555555"
                 FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
      </DockPanel>
    </TabItem>
    <TabItem Header="Profiling">
      <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="Per-tab restore timings (most recent first). head-transfer = time to stream the history over the pipe before parsing; head = the parse breakdown (feed = escape parsing, snapshot/prepend = building scrollback)." Foreground="#FFAAAAAA" Margin="0,0,0,6" />
        <TextBox x:Name="ProfilingBox" IsReadOnly="True"
                 Background="#FF1E1E1E" Foreground="#FFCCCCCC" BorderBrush="#FF555555"
                 FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
      </DockPanel>
    </TabItem>
    <TabItem x:Name="LlmTab" Header="LLM">
      <StackPanel Margin="12">
        <TextBlock Text="OpenRouter config file (the api key, or JSON with a &quot;key&quot; field):" Foreground="#FFAAAAAA" />
        <DockPanel Margin="0,4,0,0">
          <Button x:Name="BrowseConfigBtn" DockPanel.Dock="Right" Content="Browse…" Padding="10,2" Margin="6,0,0,0" Click="BrowseConfigBtn_Click" />
          <TextBox x:Name="ConfigPathBox" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="ConfigPathBox_TextChanged" />
        </DockPanel>
        <TextBlock Text="Model:" Foreground="#FFAAAAAA" Margin="0,12,0,0" />
        <ContentControl x:Name="ModelBoxHost" Margin="0,4,0,0" />
        <TextBlock x:Name="ModelListStatus" Foreground="#FF777777" FontSize="11" Margin="0,2,0,0" />
        <TextBlock Text="Context window (tokens):" Foreground="#FFAAAAAA" Margin="0,12,0,0" />
        <TextBox x:Name="ContextTokensBox" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="ContextTokensBox_TextChanged" />
        <CheckBox x:Name="LlmTriggerBox"
                  Foreground="#FFDDDDDD"
                  Margin="0,12,0,0"
                  Checked="LlmTriggerBox_Changed"
                  Unchecked="LlmTriggerBox_Changed">
          <TextBlock Text="Trigger phrases: run LLM autocomplete only when the input starts with one of these (| separated, case-insensitive, letters-only comparison)" />
        </CheckBox>
        <TextBox x:Name="LlmTriggerPhrasesBox" Margin="0,4,0,0" Background="#FF1E1E1E" Foreground="#FFE8E8E8" CaretBrush="#FFE8E8E8" BorderBrush="#FF555555" FontFamily="Consolas" TextChanged="LlmTriggerPhrasesBox_TextChanged" />
        <TextBlock x:Name="LlmStatsText" Foreground="#FFCCCCCC" FontFamily="Consolas" FontSize="12" Margin="0,16,0,0" />
        <Button x:Name="ShowContextBtn" Content="Show current context" HorizontalAlignment="Left" Margin="0,12,0,0" Padding="10,4" Click="ShowContextBtn_Click" />
      </StackPanel>
    </TabItem>
  </TabControl>
</Window>
